require sqlite_v2

statement ok
ATTACH '__TEST_DIR__/attach_unnest.sqlite' AS tmp (TYPE SQLITE);

statement ok
USE tmp;

statement ok
CREATE OR REPLACE TABLE xs AS SELECT unnest(['foo', 'bar', 'baz']) AS x;

query I
SELECT * FROM xs;
----
foo
bar
baz
