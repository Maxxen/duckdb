# name: test/sql/json_v2/table/auto_glob_directory.test
# description: Test auto globbing a directory
# group: [table]

require json_v2

statement ok
COPY (SELECT i%2 AS grp, i FROM range(1000) t(i)) TO '{TEST_DIR}/glob_dir_json' (FORMAT json, PER_THREAD_OUTPUT);

query II
SELECT grp, COUNT(*) FROM read_json('{TEST_DIR}/glob_dir_json') GROUP BY ALL ORDER BY ALL
----
0	500
1	500
